/*
 * sofle_right.overlay
 *
 * Sofle Choc RGB - Lado Direito
 * Hardware: nice!nano v2 / SuperMini NRF52840
 *
 * Inclui:
 * - Display OLED SSD1306 via I2C0
 * - Encoder/Potenciômetro (right side)
 * - Matrix transform (5 colunas direita)
 */

#include <dt-bindings/zmk/matrix_transform.h>

&pinctrl {
    /* I2C0 para display OLED */
    i2c0_default: i2c0_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 24)>,
                    <NRF_PSEL(TWIM_SCL, 0, 4)>;
        };
    };

    i2c0_sleep: i2c0_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 24)>,
                    <NRF_PSEL(TWIM_SCL, 0, 4)>;
            low-power-enable;
        };
    };

    /* GPIO para encoder (A e B) */
    encoder_pinctrl: encoder_pinctrl {
        group1 {
            psels = <NRF_PSEL(GPIO, 0, 20)>,  /* Encoder A */
                    <NRF_PSEL(GPIO, 0, 21)>;  /* Encoder B */
        };
    };
};

/* ──────────────────────────────────────────────────────
   I2C0 - Display OLED SSD1306
   ────────────────────────────────────────────────────── */
&i2c0 {
    compatible = "nordic,nrf-twim";
    status = "okay";
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";
    clock-frequency = <100000>;

    display0: ssd1306@3c {
        compatible = "solomon,ssd1306";
        reg = <0x3c>;
        label = "SSD1306_0";
        width = <128>;
        height = <32>;
        segment-offset = <0>;
        com-inverted;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <31>;
        segment-remap;
        com-sequential;
        prechargep = <0x22>;
        status = "okay";
    };
};

/* ──────────────────────────────────────────────────────
   ENCODER / POTENCIÔMETRO (Direita)
   ────────────────────────────────────────────────────── */
/ {
    /* GPIO pins para o encoder */
    encoder_right {
        compatible = "zmk,rotary-encoder-sensor";
        label = "RIGHT_ENCODER";
        a-gpios = <&gpio0 20 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
        b-gpios = <&gpio0 21 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
        steps = <20>;
        status = "okay";
    };

    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder_right>;
    };

    chosen {
        zephyr,display = &display0;
    };
};

/* ──────────────────────────────────────────────────────
   MATRIX TRANSFORM - Sofle Choc (5 colunas direita)
   ────────────────────────────────────────────────────── */
&kscan0 {
    col-gpios
        = <&pro_micro 19 GPIO_ACTIVE_HIGH>
        , <&pro_micro 18 GPIO_ACTIVE_HIGH>
        , <&pro_micro 15 GPIO_ACTIVE_HIGH>
        , <&pro_micro 14 GPIO_ACTIVE_HIGH>
        , <&pro_micro 16 GPIO_ACTIVE_HIGH>
        ;
};

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <5>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)
        >;
    };
};
